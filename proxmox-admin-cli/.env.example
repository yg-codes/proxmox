# Environment variables for Proxmox Snapshot Manager
# Copy to .env and adjust values as needed

# Proxmox connection settings
PVE_HOST=fsx-dev-pve23.fsx.zone
PVE_USER=snapshot@pve
PVE_TOKEN_NAME=snapshot
PVE_TOKEN_VALUE=350301d5-ec84-4a4f-b1ee-59222f633334

# Optional: Alternative password authentication (not recommended)
# PVE_PASSWORD=your-password

# Optional: Override default settings via environment
# PSM_PROXMOX_PORT=8006
# PSM_PROXMOX_VERIFY_SSL=false
# PSM_OPERATIONS_MAX_CONCURRENT_SNAPSHOTS=2
# PSM_LOGGING_LEVEL=info
# PSM_CLI_BATCH_MODE=false